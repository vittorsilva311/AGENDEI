// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"

}

/*
aqui tem que ser criado o model de usuário, onde serão armazenadas as informações sobre cada usuário.
*/

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  bookings   booking[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/*
aqui tem que ser criado o model de barbearia, onde serão armazenadas as informações sobre cada barbearia.
*/

model Barbershop {
  id        String   @id @default(uuid())
  name      String
  address   String
  phones    String[]
  description String
  imagemURL String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  services   Service[]
}

/*
aqui tem que ser criado o model de serviço, onde tem a relação entre o serviço e a barbearia.

*/
model Service {
  id          String   @id @default(uuid())
  name        String
  description String
  imagemURL   String
  price       Decimal @db.Decimal(10, 2)
  barbershopId String
  barbershop   Barbershop @relation(fields: [barbershopId], references: [id])
   bookings     booking[]
}

/* aqui tem que ser criado o model de booking, onde tem a relação entre o usuário, 
o serviço e a data do agendamento. O usuário pode ter vários agendamentos, e cada agendamento está relacionado a um serviço específico. 
O modelo de booking deve conter os campos necessários para armazenar essas informações, como userId, serviceId, date, createdAt e updatedAt.
 Além disso, deve haver uma relação entre o modelo de booking e os modelos de User e Service para garantir a integridade dos dados.*/
model booking {
  id          String   @id @default(uuid())
  userId      String
  serviceId   String
  date        DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User    @relation(fields: [userId], references: [id])
  service     Service @relation(fields: [serviceId], references: [id])
}